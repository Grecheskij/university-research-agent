# Секреты LLM и внешних источников
GEMINI_API_KEY=             # Ключ Google Gemini (Google AI Studio)
OPENROUTER_API_KEY=         # Ключ OpenRouter для OpenAI-compatible fallback
GROQ_API_KEY=               # Ключ Groq для резервной модели
UNPAYWALL_EMAIL=            # Email для Unpaywall API
SEMANTIC_SCHOLAR_KEY=       # Опциональный ключ Semantic Scholar
RESEARCH_AGENT_CONTACT_EMAIL= # Контактный email для User-Agent запросов

# Модели и исследовательские настройки
LLM_PROVIDER=auto           # auto / gemini / openrouter / groq
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=openrouter/free  # Рекомендуемый бесплатный дефолт для OpenRouter
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:7860
OPENROUTER_APP_TITLE=University Research Agent
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
CHROMA_COLLECTION_NAME=research_papers
CHROMA_PATH=./data/chroma_db
RESEARCH_MAX_RESULTS=10
RESEARCH_RETRY_ATTEMPTS=3
RESEARCH_RETRY_MIN_SECONDS=1
RESEARCH_RETRY_MAX_SECONDS=8
HTTP_TIMEOUT_SECONDS=30

# Базовые URL внешних API
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
OPENALEX_BASE_URL=https://api.openalex.org
CROSSREF_BASE_URL=https://api.crossref.org
ARXIV_BASE_URL=http://export.arxiv.org/api
UNPAYWALL_BASE_URL=https://api.unpaywall.org/v2

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_APP_NAME=University Research Agent API
BACKEND_APP_DESCRIPTION=FastAPI service for research search, review, bibliography, and analytics.
BACKEND_APP_VERSION=0.2.0
BACKEND_MAX_REQUEST_BYTES=1048576
FRONTEND_ORIGINS=http://localhost:7860,http://localhost:8000
HF_SPACE_URL=               # URL Hugging Face Space для CORS
API_KEY=                    # Опциональный X-API-Key для защищённых эндпоинтов
BACKEND_API_KEY=            # Альтернативное имя для того же API-ключа

# Frontend / Gradio
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=7860
FRONTEND_HTTP_TIMEOUT=30
FRONTEND_LANG_DEFAULT=ru
AUTO_START_BACKEND=1        # 1 — Gradio поднимает локальный backend в фоне

# Логи
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
